# Pick a backend. "cli" (default) shells out to `claude -p` and bills against
# your Claude Code subscription (slower, no API key needed). "api" uses the
# Anthropic SDK with ANTHROPIC_API_KEY.
LLM_BACKEND=cli

# Required when LLM_BACKEND=api. Leave blank if you're on the cli backend.
ANTHROPIC_API_KEY=

# Optional override for the embedding model used in dedup.
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional model overrides. With LLM_BACKEND=cli these are mapped to short
# aliases ("opus"/"sonnet"/"haiku") that the CLI resolves against your tier.
RANKING_MODEL=claude-sonnet-4-6
BLURB_MODEL=claude-opus-4-7
