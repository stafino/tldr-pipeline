# data/blurbs/<date>.jsonl
# data/issues/<nl>-<date>.txt
data/embeddings_cache/
.env
uv.lock
.streamlit/secrets.toml

# Next.js viewer in web/ (its own .gitignore also applies)
web/node_modules/
web/.next/
web/.vercel/
web/*.log

# Source brand assets (canonical copies live under web/app/ and web/public/)
trylede-assets/
data/funding/.tweeted.json
