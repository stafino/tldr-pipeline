#!/usr/bin/env bash
#
# tldr — one-shot driver for the tldr-pipeline. Multi-newsletter aware.
#
# Usage:
#   tldr                  → full pipeline (ingest → dedup → rank → blurbs ALL → format ALL) then open UI
#   tldr refresh          → full pipeline only, no UI
#   tldr ui               → open the Streamlit review UI
#   tldr ingest|dedup|rank
#                         → run a single step (newsletter-agnostic)
#   tldr blurbs [<nl_id>]
#                         → generate blurbs for all newsletters (default) or one
#   tldr format [<nl_id>]
#                         → render the formatted issue for all (default) or one
#   tldr backtest <start> <end> [<nl_id>]
#                         → backtest against real TLDR archive(s)
#   tldr open [<nl_id>]   → open today's rendered issue ($EDITOR)
#   tldr status           → counts for today's pipeline (raw / deduped / scored / blurbed)
#   tldr list             → list newsletters
#   tldr help             → this message
#
# Environment overrides:
#   DATE=2026-06-14       → run for a specific date (default: today)
#   LLM_BACKEND=cli|api   → override LLM backend
#   MIN_ASSIGNMENT_SCORE=55  → minimum per-newsletter score to keep an assignment

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$REPO_ROOT"

DATE="${DATE:-$(date +%Y-%m-%d)}"

err()  { printf '\033[31m%s\033[0m\n' "$*" >&2; }
log()  { printf '\033[36m▸ %s\033[0m\n' "$*"; }
ok()   { printf '\033[32m✓ %s\033[0m\n' "$*"; }

if ! command -v uv >/dev/null 2>&1; then
  err "uv is not installed. Install it with:"
  err "  curl -LsSf https://astral.sh/uv/install.sh | sh"
  exit 1
fi

if [[ ! -d ".venv" ]]; then
  log "first run — installing dependencies with uv sync"
  uv sync
fi

cmd_ingest() { log "ingest  date=$DATE"; uv run python -m ingestion.run --date "$DATE"; }
cmd_dedup()  { log "dedup   date=$DATE"; uv run python -m dedup.run --date "$DATE"; }
cmd_rank()   { log "rank    date=$DATE (multi-newsletter)"; uv run python -m ranking.run --date "$DATE"; }

cmd_blurbs() {
  local nl="${1:-all}"
  log "blurbs  date=$DATE  newsletter=$nl"
  uv run python -m blurbs.run --date "$DATE" --newsletter "$nl"
}

cmd_format() {
  local nl="${1:-all}"
  log "format  date=$DATE  newsletter=$nl"
  uv run python -m formatters.tldr --date "$DATE" --newsletter "$nl"
}

cmd_refresh() {
  cmd_ingest
  cmd_dedup
  cmd_rank
  cmd_blurbs "all"
  cmd_format "all"
  ok "done — issues at data/issues/*-${DATE}.txt"
}

cmd_ui() {
  log "launching Streamlit UI at http://localhost:8501"
  exec uv run streamlit run ui/app.py
}

cmd_backtest() {
  local start="${1:-}"; local end="${2:-}"; local nl="${3:-all}"
  if [[ -z "$start" || -z "$end" ]]; then
    err "usage: tldr backtest <start> <end> [<nl_id>]"
    exit 1
  fi
  uv run python scripts/backtest.py --start "$start" --end "$end" --newsletter "$nl"
}

cmd_backtest_cache() {
  # Update the backtest cache for the last 7 days (covers today + 6 prior).
  local today; today="$(date +%Y-%m-%d)"
  local start; start="$(date -v-6d +%Y-%m-%d 2>/dev/null || date -d '6 days ago' +%Y-%m-%d)"
  log "backtest cache: $start → $today"
  uv run python scripts/run_backtest_cache.py --start "$start" --end "$today"
}

cmd_open() {
  local nl="${1:-tldr_tech}"
  local f="data/issues/${nl}-${DATE}.txt"
  if [[ ! -f "$f" ]]; then
    err "no rendered issue at $f. Run 'tldr format $nl' first."
    exit 1
  fi
  "${EDITOR:-cat}" "$f"
}

_count_lines() {
  [[ -f "$1" ]] && wc -l <"$1" | tr -d ' ' || echo 0
}

cmd_status() {
  echo "date=$DATE"
  printf "  %-10s %s\n" "raw"      "$(_count_lines "data/raw/${DATE}.jsonl")"
  printf "  %-10s %s\n" "deduped"  "$(_count_lines "data/deduped/${DATE}.jsonl")"
  printf "  %-10s %s\n" "scored"   "$(_count_lines "data/scored/${DATE}.jsonl")"
  printf "  %-10s %s\n" "blurbed"  "$(_count_lines "data/blurbs/${DATE}.jsonl")"
  echo "issues rendered:"
  ls -1 "data/issues/" 2>/dev/null | grep -- "-${DATE}.txt" | sed 's/^/  /'
}

cmd_list() {
  uv run python -c "
from common.newsletters import load_newsletters
for nid, nl in load_newsletters().items():
    secs = ', '.join(s.name for s in nl.sections)
    print(f'{nid:<18} {nl.brand_name:<20} sections: {secs}')
"
}

cmd_help() {
  sed -n '2,22p' "$0" | sed 's/^# \{0,1\}//'
}

main() {
  local sub="${1:-default}"
  case "$sub" in
    default)             cmd_refresh && cmd_ui ;;
    refresh|all)         cmd_refresh ;;
    ui|web|streamlit)    cmd_ui ;;
    ingest)              cmd_ingest ;;
    dedup)               cmd_dedup ;;
    rank)                cmd_rank ;;
    blurbs)              shift; cmd_blurbs "${1:-all}" ;;
    format|render)       shift; cmd_format "${1:-all}" ;;
    backtest)            shift; cmd_backtest "$@" ;;
    backtest_cache|cache_backtest)  cmd_backtest_cache ;;
    open|edit)           shift; cmd_open "${1:-tldr_tech}" ;;
    status)              cmd_status ;;
    list|ls)             cmd_list ;;
    help|-h|--help)      cmd_help ;;
    *)
      err "unknown subcommand: $sub"
      echo
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
